modules = ["java-graalvm22.3"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Build Android App"

[[workflows.workflow]]
name = "Build Android App"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "./gradlew tasks --all 2>&1 | head -100"

[workflows.workflow.metadata]
outputType = "console"
